# Required: admin login/session
# Use a long random value for ADMIN_SESSION_SECRET.
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Required: PostgreSQL persistence
# Use DATABASE_URL locally, or rely on Vercel Postgres-provided POSTGRES_URL in production.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cv_charles_mn

# Optional: direct non-pooled connection for local/manual migrations
POSTGRES_URL_NON_POOLING=

# Deprecated: Firebase client/env vars are no longer used for active persistence
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Deprecated: Firebase Admin env vars are no longer used for active persistence
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
